# Renteo Web — environment template.
# Copy to .env.local (gitignored) for local dev. NEVER commit secrets.

# Supabase (públicos: el anon key sale en el bundle del cliente).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API backend (apps/api).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry (opcional). Sin DSN el SDK queda no-op (CI / dev local).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_VERSION=
# Sourcemaps + release tracking (build time, server-only).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
