# Renteo API — environment template.
# Copy to .env (gitignored) for local dev. NEVER commit secrets.

ENVIRONMENT=local
APP_VERSION=0.0.0

# Supabase
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
DATABASE_URL=

# Workers
REDIS_URL=

# AWS (sa-east-1 preferred)
AWS_REGION=sa-east-1
KMS_CERTS_KEY_ARN=
S3_CERTS_BUCKET=

# SII providers
SII_PROVIDER_PRIMARY=simpleapi
SII_PROVIDER_BACKUP=baseapi

# Observability
SENTRY_DSN=
