{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renteo.cl/schemas/tax_rules/red_flag.json",
  "title": "Bandera roja global del motor",
  "description": "Banderas rojas (skill 1) que bloquean automáticamente patrones de la lista negra. Evaluadas por rule_evaluator contra el contexto del cálculo.",
  "type": "object",
  "required": ["id", "severidad", "condicion", "mensaje", "fundamento"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "severidad": { "enum": ["block", "warn"] },
    "condicion": { "$ref": "#/$defs/clause" },
    "mensaje": { "type": "string", "minLength": 1 },
    "fundamento": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "clause": {
      "anyOf": [
        { "$ref": "#/$defs/predicate" },
        { "$ref": "#/$defs/all_of" },
        { "$ref": "#/$defs/any_of" },
        { "$ref": "#/$defs/not" }
      ]
    },
    "predicate": {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "op": {
          "enum": [
            "eq", "neq", "lt", "lte", "gt", "gte",
            "between", "in", "not_in",
            "exists", "not_exists",
            "matches_regex"
          ]
        },
        "value": {},
        "message": { "type": "string" },
        "fundamento": { "type": "string" }
      }
    },
    "all_of": {
      "type": "object",
      "required": ["all_of"],
      "additionalProperties": false,
      "properties": {
        "all_of": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clause" }
        }
      }
    },
    "any_of": {
      "type": "object",
      "required": ["any_of"],
      "additionalProperties": false,
      "properties": {
        "any_of": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clause" }
        }
      }
    },
    "not": {
      "type": "object",
      "required": ["not"],
      "additionalProperties": false,
      "properties": {
        "not": { "$ref": "#/$defs/clause" }
      }
    }
  }
}
